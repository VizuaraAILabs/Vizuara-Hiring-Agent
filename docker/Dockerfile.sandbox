FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies (no nodejs here — we install it separately)
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    curl git wget \
    build-essential ca-certificates gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 from NodeSource
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code

# Pre-configure Claude Code: create config dirs and tool permissions
RUN mkdir -p /root/.claude && \
    echo '{"permissions":{"allow":["Bash(*)","Read(*)","Edit(*)","Write(*)","WebFetch(*)"]}}' > /root/.claude/settings.json && \
    echo "alias claude='claude --dangerously-skip-permissions'" >> /root/.bashrc

# Entrypoint script: writes Claude Code config with the runtime API key,
# then keeps the container alive. The terminal server attaches via exec.
RUN cat > /entrypoint.sh << 'SCRIPT'
#!/bin/bash
if [ -n "$ANTHROPIC_API_KEY" ]; then
    cat > /root/.claude.json << EOF
{"hasCompletedOnboarding":true,"primaryApiKey":"$ANTHROPIC_API_KEY"}
EOF
fi
# Keep container alive (terminal server attaches via docker exec)
exec sleep infinity
SCRIPT
RUN chmod +x /entrypoint.sh

# Pre-install RAG challenge Python deps
COPY challenges/rag-retrieval/requirements.txt /tmp/rag-reqs.txt
RUN pip3 install --no-cache-dir -r /tmp/rag-reqs.txt && rm /tmp/rag-reqs.txt

# Download NLTK data commonly needed
RUN python3 -c "import nltk; nltk.download('punkt'); nltk.download('punkt_tab'); nltk.download('stopwords')"

# Create workspace directory
RUN mkdir -p /workspace
WORKDIR /workspace

# Entrypoint configures Claude Code with runtime API key, then sleeps
CMD ["/entrypoint.sh"]
