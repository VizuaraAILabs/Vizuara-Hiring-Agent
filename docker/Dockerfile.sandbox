FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    nodejs npm \
    curl git wget \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 via NodeSource
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code

# Pre-install RAG challenge Python deps
COPY challenges/rag-retrieval/requirements.txt /tmp/rag-reqs.txt
RUN pip3 install --no-cache-dir -r /tmp/rag-reqs.txt && rm /tmp/rag-reqs.txt

# Download NLTK data commonly needed
RUN python3 -c "import nltk; nltk.download('punkt'); nltk.download('punkt_tab'); nltk.download('stopwords')"

# Create workspace directory
RUN mkdir -p /workspace
WORKDIR /workspace

# Default shell
CMD ["/bin/bash", "-l"]
