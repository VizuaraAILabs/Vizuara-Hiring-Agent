FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies (no nodejs here — we install it separately)
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    curl git wget \
    build-essential ca-certificates gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 from NodeSource
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code

# Pre-configure Claude Code: create config dirs and bypass first-run onboarding
RUN mkdir -p /root/.claude && \
    echo '{"hasCompletedOnboarding":true}' > /root/.claude.json && \
    echo '{"permissions":{"allow":["Bash(*)","Read(*)","Edit(*)","Write(*)","WebFetch(*)"]}}' > /root/.claude/settings.json

# Pre-install RAG challenge Python deps
COPY challenges/rag-retrieval/requirements.txt /tmp/rag-reqs.txt
RUN pip3 install --no-cache-dir -r /tmp/rag-reqs.txt && rm /tmp/rag-reqs.txt

# Download NLTK data commonly needed
RUN python3 -c "import nltk; nltk.download('punkt'); nltk.download('punkt_tab'); nltk.download('stopwords')"

# Create workspace directory
RUN mkdir -p /workspace
WORKDIR /workspace

# Default shell
CMD ["/bin/bash", "-l"]
