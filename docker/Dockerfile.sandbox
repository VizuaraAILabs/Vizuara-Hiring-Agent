FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies (no nodejs here — we install it separately)
# Use --no-install-recommends to reduce image size
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    curl git wget sudo nano \
    build-essential ca-certificates gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 from NodeSource
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code globally, then create a wrapper that auto-skips
# all interactive prompts (safe because sandbox is fully isolated in Docker)
RUN npm install -g @anthropic-ai/claude-code && \
    npm cache clean --force && \
    CLAUDE_BIN=$(which claude) && \
    mv "$CLAUDE_BIN" "${CLAUDE_BIN}-real" && \
    printf '#!/bin/bash\nset -e\nFILTERED_ARGS=()\nwhile [ "$#" -gt 0 ]; do\n  case "$1" in\n    --model|-m)\n      shift\n      if [ "$#" -gt 0 ]; then shift; fi\n      ;;\n    --model=*|-m=*)\n      shift\n      ;;\n    *)\n      FILTERED_ARGS+=("$1")\n      shift\n      ;;\n  esac\ndone\nexec "%s-real" --dangerously-skip-permissions --model "claude-haiku-4-5-20251001" "${FILTERED_ARGS[@]}"\n' "$CLAUDE_BIN" > "$CLAUDE_BIN" && \
    chmod +x "$CLAUDE_BIN"

# Remove build-essential now that npm global install is done (saves ~200MB)
RUN apt-get update && apt-get purge -y build-essential && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

# Create non-root candidate user (--dangerously-skip-permissions requires non-root).
# Candidate sandboxes are untrusted and must not be able to escalate into
# host-provided secrets.
RUN useradd -m -s /bin/bash candidate && \
    mkdir -p /home/candidate/.claude

# Keep `ls` output visually plain, but mark directories with a trailing slash.
RUN printf "\nalias ls='ls -p --color=never'\n" >> /home/candidate/.bashrc && \
    chown candidate:candidate /home/candidate/.bashrc

# Pre-configure Claude Code for candidate user
RUN echo '{"skipDangerousModePermissionPrompt":true,"permissions":{"allow":["Bash(*)","Read(*)","Edit(*)","Write(*)","WebFetch(*)"]}}' > /home/candidate/.claude/settings.json && \
    echo '{"hasCompletedOnboarding":true}' > /home/candidate/.claude.json && \
    chown -R candidate:candidate /home/candidate/.claude /home/candidate/.claude.json

# Pre-install RAG challenge Python deps
COPY challenges/rag-retrieval/requirements.txt /tmp/rag-reqs.txt
RUN pip3 install --no-cache-dir -r /tmp/rag-reqs.txt && rm /tmp/rag-reqs.txt

# Download NLTK data commonly needed
RUN python3 -c "import nltk; nltk.download('punkt'); nltk.download('punkt_tab'); nltk.download('stopwords')"

# Create workspace directory owned by candidate
RUN mkdir -p /workspace && chown candidate:candidate /workspace
WORKDIR /workspace

# Entrypoint keeps the container alive. Anthropic credentials must never be
# written into this untrusted candidate sandbox.
COPY docker/sandbox-entrypoint.sh /entrypoint.sh
USER root
RUN sed -i 's/\r$//' /entrypoint.sh && chmod +x /entrypoint.sh
USER candidate

CMD ["/entrypoint.sh"]
