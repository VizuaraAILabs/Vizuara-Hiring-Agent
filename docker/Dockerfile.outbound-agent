FROM node:20-alpine AS builder
WORKDIR /app
COPY services/outbound-agent/package.json services/outbound-agent/tsconfig.json ./
RUN npm install
COPY services/outbound-agent/src ./src
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=8080
RUN apk add --no-cache bash git ripgrep && npm install -g @anthropic-ai/claude-code
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/src/prompts ./dist/prompts
EXPOSE 8080
CMD ["node", "dist/server.js"]
