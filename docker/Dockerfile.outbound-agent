FROM node:20-alpine AS builder
WORKDIR /app
COPY services/outbound-agent/package.json services/outbound-agent/tsconfig.json ./
RUN npm install
COPY services/outbound-agent/src ./src
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=8080
COPY --from=builder /app/dist ./dist
EXPOSE 8080
CMD ["node", "dist/server.js"]
