# ArcEval environment example
# Copy this file to .env.local for local development or .env.production for deployment.
# Replace every placeholder value with real secrets for your environment.

# ---------------------------------------------------------------------------
# Shared app/domain settings
# ---------------------------------------------------------------------------
DOMAIN=localhost
NODE_ENV=development
DATABASE_URL=postgresql://hiring:hiring@localhost:5432/hiring_agent

# Public Vizuara/auth URLs
NEXT_PUBLIC_VIZUARA_URL=https://vizuara.ai
NEXT_PUBLIC_APP_CALLBACK_URL=http://localhost:3000/api/auth/session
NEXT_PUBLIC_PAYMENT_URL=https://vizuara.ai/courses/arceval
COOKIE_DOMAIN=

# Course/subscription integration
ARCEVAL_ENROLLMENT_ID=course_xxxxx
ARCEVAL_PAYMENT_URL=https://vizuara.ai/courses/arceval

# Internal service URLs
ANALYSIS_ENGINE_URL=http://localhost:8000
NEXT_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Firebase client config, exposed to browser because of NEXT_PUBLIC_ prefix
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Firebase Admin SDK, server-side only
# Keep escaped newlines as \n when storing this on one line.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Gemini, used by web challenge generation and analysis engine
# ---------------------------------------------------------------------------
# Multiple keys can be comma-separated for fallback rotation.
GEMINI_API_KEY=your_gemini_api_key
# Optional alias; the analysis engine can read either, but compose maps this too.
GOOGLE_API_KEY=your_gemini_api_key

# Hard timeout for each Gemini HTTP request, in milliseconds.
GEMINI_REQUEST_TIMEOUT_MS=60000

# Operation-level analysis deadlines, in seconds.
ANALYSIS_SESSION_TIMEOUT_SECONDS=240
ANALYSIS_ENRICHMENT_TIMEOUT_SECONDS=75
ANALYSIS_NARRATIVE_TIMEOUT_SECONDS=105

# Analysis queue controls
ANALYSIS_MAX_CONCURRENT=2
ANALYSIS_QUEUE_POLL_SECONDS=2
ANALYSIS_JOB_LEASE_SECONDS=300

# ---------------------------------------------------------------------------
# Terminal/sandbox service
# ---------------------------------------------------------------------------
TERMINAL_PORT=3001
TERMINAL_SERVER_ID=local-terminal-3001
TERMINAL_RUNTIME_LEASE_SECONDS=90
NEXT_PUBLIC_TERMINAL_WS_URL=ws://localhost:3001
NEXT_PUBLIC_TERMINAL_HTTP_URL=http://localhost:3001

ANTHROPIC_API_KEY=your_anthropic_api_key
SANDBOX_CLAUDE_MODEL=claude-haiku-4-5-20251001
SANDBOX_IMAGE=hiring-sandbox
SANDBOX_MAX_CONCURRENT=2
SANDBOX_IDLE_TTL_MS=900000
SANDBOX_QUEUE_TIMEOUT_MS=60000
DOCKER_SOCKET_PATH=/var/run/docker.sock

# ---------------------------------------------------------------------------
# Email and scheduled jobs
# ---------------------------------------------------------------------------
BREVO_API_KEY=your_brevo_api_key
CRON_SECRET=replace_with_a_long_random_secret
